{"config":{"lang":["en"],"separator":"[\\s\\u200b\\u3000\\-\u3001\u3002\uff0c\uff0e\uff1f\uff01\uff1b]+","pipeline":["stemmer"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"\u9996\u9875","text":"<p>\u6b22\u8fce\u6765\u5230\u6211\u7684\u7f16\u7a0b\u535a\u5ba2\uff01\u6211\u5728\u8fd9\u91cc\u5206\u4eab Python\u3001\u8f6f\u4ef6\u5de5\u7a0b \u4ee5\u53ca\u7f16\u7a0b\u5b66\u4e60\u8def\u4e0a\u7684\u70b9\u70b9\u6ef4\u6ef4\u3002</p>"},{"location":"#_2","title":"\u5173\u4e8e\u672c\u535a\u5ba2","text":"<p>\u8fd9\u662f\u6211\u8bb0\u5f55\u7f16\u7a0b\u65c5\u7a0b\u7684\u5730\u65b9 \u2014\u2014 \u5305\u62ec\u6280\u5de7\u603b\u7ed3\u3001\u6559\u7a0b\u3001\u9879\u76ee\u590d\u76d8\u548c\u7ecf\u9a8c\u6559\u8bad\u3002\u6211\u76f8\u4fe1\u628a\u5b66\u5230\u7684\u4e1c\u897f\u5199\u4e0b\u6765\uff0c\u65e2\u80fd\u52a0\u6df1\u7406\u89e3\uff0c\u4e5f\u80fd\u4e0e\u4ed6\u4eba\u5206\u4eab\u77e5\u8bc6\u3002</p>"},{"location":"#_3","title":"\u6211\u4f1a\u5199\u4e9b\u4ec0\u4e48","text":"<ul> <li>Python \u2014 \u4f7f\u7528\u6280\u5de7\u3001\u8bbe\u8ba1\u6a21\u5f0f\u548c\u6df1\u5ea6\u63a2\u7d22</li> <li>\u8f6f\u4ef6\u5de5\u7a0b \u2014 \u6700\u4f73\u5b9e\u8df5\u3001\u67b6\u6784\u8bbe\u8ba1\u548c\u4ee3\u7801\u8d28\u91cf</li> <li>DevOps \u4e0e\u5de5\u5177 \u2014 \u8ba9\u5f00\u53d1\u5de5\u4f5c\u6d41\u66f4\u52a0\u987a\u7545</li> <li>\u5f00\u6e90 \u2014 \u53c2\u4e0e\u5f00\u6e90\u793e\u533a\uff0c\u5411\u793e\u533a\u5b66\u4e60</li> </ul>"},{"location":"#_4","title":"\u6700\u65b0\u6587\u7ae0","text":"<p>\u67e5\u770b \u535a\u5ba2 \u83b7\u53d6\u5168\u90e8\u6587\u7ae0\uff0c\u6216\u76f4\u63a5\u6d4f\u89c8\u6700\u8fd1\u7684\u6587\u7ae0\u3002</p>"},{"location":"blog/","title":"Blog","text":""},{"location":"blog/posts/code-review-best-practices/","title":"\u4ee3\u7801\u5ba1\u67e5\u6700\u4f73\u5b9e\u8df5\u603b\u7ed3","text":"<p>\u7ecf\u8fc7\u591a\u5e74\u7684\u4ee3\u7801\u5ba1\u67e5\uff08\u4ee5\u53ca\u88ab\u5ba1\u67e5\uff09\u7ecf\u9a8c\uff0c\u4ee5\u4e0b\u662f\u4e00\u4e9b\u8ba9\u5ba1\u67e5\u9ad8\u6548\u800c\u975e\u75db\u82e6\u7684\u505a\u6cd5\u3002</p>"},{"location":"blog/posts/code-review-best-practices/#_2","title":"\u4f5c\u4e3a\u5ba1\u67e5\u8005","text":""},{"location":"blog/posts/code-review-best-practices/#1","title":"1. \u5ba1\u67e5\u4ee3\u7801\uff0c\u800c\u975e\u5ba1\u67e5\u4eba","text":"<p>\u5173\u6ce8\u4ee3\u7801\u672c\u8eab\uff0c\u800c\u4e0d\u662f\u5199\u4ee3\u7801\u7684\u4eba\u3002\u4f7f\u7528\u4e2d\u7acb\u7684\u8bed\u8a00\uff1a</p> \u4e0d\u597d \u66f4\u597d \"\u4f60\u5fd8\u8bb0\u5904\u7406\u9519\u8bef\u4e86\" \"\u5f53 <code>response</code> \u4e3a <code>null</code> \u65f6\u4f1a\u53d1\u751f\u4ec0\u4e48\uff1f\" \"\u8fd9\u662f\u9519\u7684\" \"\u6211\u89c9\u5f97\u8fd9\u91cc\u53ef\u80fd\u6f0f\u6389\u4e86\u2026\u2026\u7684\u8fb9\u7f18\u60c5\u51b5\""},{"location":"blog/posts/code-review-best-practices/#2","title":"2. \u5148\u6307\u51fa\u597d\u7684\u5730\u65b9","text":"<p>\u80af\u5b9a\u597d\u7684\u6a21\u5f0f\u80fd\u5f3a\u5316\u5b83\u4eec\u3002\u4e00\u53e5\u7b80\u5355\u7684\"\u8fd9\u91cc\u7528 <code>defaultdict</code> \u5f88\u5de7\u5999\"\u80fd\u62c9\u8fd1\u8ddd\u79bb\u3002</p>"},{"location":"blog/posts/code-review-best-practices/#3","title":"3. \u533a\u5206\u5c0f\u95ee\u9898\u548c\u963b\u585e\u9879","text":"<p>\u7528\u6807\u7b7e\u6765\u8bbe\u5b9a\u671f\u671b\uff1a</p> <ul> <li>[blocker] \u2014 \u5fc5\u987b\u4fee\u6539\u624d\u80fd\u5408\u5e76</li> <li>[nit] \u2014 \u98ce\u683c\u504f\u597d\uff0c\u4f5c\u8005\u53ef\u81ea\u884c\u51b3\u5b9a\u662f\u5426\u4fee\u6539</li> <li>[question] \u2014 \u6211\u4e0d\u592a\u7406\u89e3\uff0c\u8bf7\u89e3\u91ca\u4e00\u4e0b</li> </ul>"},{"location":"blog/posts/code-review-best-practices/#4-60","title":"4. \u4e00\u6b21\u5ba1\u67e5\u4e0d\u8d85\u8fc7 60 \u5206\u949f","text":"<p>\u8d85\u8fc7\u4e00\u5c0f\u65f6\u540e\u6ce8\u610f\u529b\u4f1a\u4e0b\u964d\u3002\u4f11\u606f\u4e00\u4e0b\u518d\u56de\u6765\u3002</p>"},{"location":"blog/posts/code-review-best-practices/#_3","title":"\u4f5c\u4e3a\u4ee3\u7801\u4f5c\u8005","text":""},{"location":"blog/posts/code-review-best-practices/#1-pr","title":"1. \u5c0f PR \u624d\u662f\u738b\u9053","text":"<p>200 \u884c\u7684 PR \u5f88\u5feb\u5c31\u80fd\u5ba1\u5b8c\u30022000 \u884c\u7684 PR \u53ef\u80fd\u6401\u7f6e\u4e00\u5468\u3002\u628a\u5927\u6539\u52a8\u62c6\u5206\u6210\u53ef\u5ba1\u67e5\u7684\u5c0f\u5757\u3002</p>"},{"location":"blog/posts/code-review-best-practices/#2_1","title":"2. \u5148\u81ea\u5ba1\u4e00\u904d","text":"<p>\u5728\u8bf7\u6c42\u5ba1\u67e5\u4e4b\u524d\uff0c\u81ea\u5df1\u5148\u8fc7\u4e00\u904d diff\u3002\u4f60\u4f1a\u53d1\u73b0\u4e00\u534a\u7684\u95ee\u9898\u81ea\u5df1\u5c31\u80fd\u63ea\u51fa\u6765\u3002</p>"},{"location":"blog/posts/code-review-best-practices/#3-pr","title":"3. \u5199\u597d PR \u63cf\u8ff0","text":"<pre><code>## \u505a\u4e86\u4ec0\u4e48\n\u4e3a\u652f\u4ed8 API \u5ba2\u6237\u7aef\u6dfb\u52a0\u91cd\u8bd5\u903b\u8f91\u3002\n\n## \u4e3a\u4ec0\u4e48\n\u95f4\u6b47\u6027\u7f51\u7edc\u9519\u8bef\u5bfc\u81f4\u7ea6 2% \u7684\u652f\u4ed8\u8bf7\u6c42\u5931\u8d25\u3002\n\u672c\u6b21\u6dfb\u52a0\u4e86\u6307\u6570\u9000\u907f\u91cd\u8bd5\uff08\u6700\u591a 3 \u6b21\uff0c\u6700\u957f 10 \u79d2\uff09\u3002\n\n## \u6d4b\u8bd5\u8ba1\u5212\n- [x] \u91cd\u8bd5\u6b21\u6570\u7684\u5355\u5143\u6d4b\u8bd5\n- [x] \u4f7f\u7528\u8fd4\u56de 500 \u7684 mock \u670d\u52a1\u5668\u505a\u96c6\u6210\u6d4b\u8bd5\n- [x] \u5728\u9884\u53d1\u5e03\u73af\u5883\u624b\u52a8\u6d4b\u8bd5\n</code></pre>"},{"location":"blog/posts/code-review-best-practices/#4","title":"4. \u4e0d\u8981\u628a\u53cd\u9988\u5f53\u6210\u9488\u5bf9\u4e2a\u4eba","text":"<p>\u5ba1\u67e5\u662f\u4e3a\u4e86\u8ba9\u4ea7\u54c1\u66f4\u597d\uff0c\u4e0d\u662f\u9488\u5bf9\u4f60\u3002\u5982\u679c\u611f\u5230\u4e0d\u9002\uff0c\u5148\u79bb\u5f00 10 \u5206\u949f\u518d\u56de\u6765\u56de\u590d\u3002</p>"},{"location":"blog/posts/code-review-best-practices/#_4","title":"\u603b\u7ed3","text":"<p>PR \u8981\u5c0f\u3001\u5ba1\u67e5\u8981\u5c0a\u91cd\u3001\u6c9f\u901a\u8981\u6e05\u6670\u3002\u4ee3\u7801\u5ba1\u67e5\u662f\u4e00\u573a\u5bf9\u8bdd\uff0c\u4e0d\u662f\u4e00\u9053\u5173\u5361\u3002</p> <p>\u4f60\u6709\u4ec0\u4e48\u4ee3\u7801\u5ba1\u67e5\u7684\u69fd\u70b9\uff1f\u6b22\u8fce\u5206\u4eab\uff01</p>"},{"location":"blog/posts/getting-started-with-mkdocs-material/","title":"MkDocs Material \u535a\u5ba2\u642d\u5efa\u6307\u5357","text":"<p>\u6700\u8fd1\u642d\u5efa\u4e86\u8fd9\u4e2a\u535a\u5ba2\u6765\u8bb0\u5f55\u7f16\u7a0b\u65c5\u7a0b\u3002\u4e0b\u9762\u7b80\u5355\u4ecb\u7ecd\u4e00\u4e0b\u5b83\u7684\u6784\u5efa\u65b9\u5f0f\u3002</p>"},{"location":"blog/posts/getting-started-with-mkdocs-material/#mkdocs-material_1","title":"\u4e3a\u4ec0\u4e48\u9009 MkDocs Material\uff1f","text":"<p>MkDocs Material \u662f\u4e00\u4e2a\u57fa\u4e8e MkDocs \u7684\u5f3a\u5927\u9759\u6001\u7ad9\u70b9\u751f\u6210\u5668\u3002\u5b83\u7684\u4f18\u52bf\u5305\u62ec\uff1a</p> <ul> <li>\u7eaf Markdown \u2014 \u4f7f\u7528 Markdown \u548c YAML \u5143\u6570\u636e\u7f16\u5199\u6587\u7ae0</li> <li>\u5185\u7f6e\u535a\u5ba2\u63d2\u4ef6 \u2014 \u5f00\u7bb1\u5373\u7528\u7684\u5206\u7c7b\u3001\u4f5c\u8005\u3001\u5f52\u6863\u548c\u5206\u9875\u529f\u80fd</li> <li>\u7cbe\u7f8e\u7684\u4ee3\u7801\u9ad8\u4eae \u2014 \u5e26\u590d\u5236\u6309\u94ae\u7684\u8bed\u6cd5\u9ad8\u4eae</li> <li>\u6df1\u8272\u6a21\u5f0f \u2014 \u81ea\u52a8\u5207\u6362\u6d45\u8272/\u6df1\u8272\u4e3b\u9898</li> <li>\u5feb\u901f\u641c\u7d22 \u2014 \u5e26\u5efa\u8bae\u7684\u5168\u6587\u641c\u7d22</li> </ul>"},{"location":"blog/posts/getting-started-with-mkdocs-material/#_1","title":"\u9879\u76ee\u7ed3\u6784","text":"<pre><code>blog/\n\u251c\u2500\u2500 mkdocs.yml          # \u7ad9\u70b9\u914d\u7f6e\n\u251c\u2500\u2500 docs/\n\u2502   \u251c\u2500\u2500 index.md        # \u9996\u9875\n\u2502   \u2514\u2500\u2500 blog/\n\u2502       \u2514\u2500\u2500 posts/      # \u535a\u5ba2\u6587\u7ae0\n\u2502           \u2514\u2500\u2500 *.md    # \u6bcf\u7bc7\u6587\u7ae0\u662f\u4e00\u4e2a Markdown \u6587\u4ef6\n\u2514\u2500\u2500 venv/               # Python \u865a\u62df\u73af\u5883\n</code></pre>"},{"location":"blog/posts/getting-started-with-mkdocs-material/#_2","title":"\u5feb\u901f\u5f00\u59cb","text":"<pre><code># \u5b89\u88c5\u4f9d\u8d56\npip install mkdocs-material\n\n# \u521b\u5efa\u65b0\u6587\u7ae0\ncd docs/blog/posts\ncat &gt; my-post.md &lt;&lt; 'EOF'\n---\ndate: 2026-04-25\nauthors:\n  - liyao\ntitle: \u6211\u7684\u65b0\u6587\u7ae0\ncategories:\n  - \u901a\u7528\n---\n\n# \u6211\u7684\u65b0\u6587\u7ae0\n\n\u5728\u8fd9\u91cc\u5199\u4e0b\u4f60\u7684\u5185\u5bb9\u3002\nEOF\n\n# \u542f\u52a8\u5f00\u53d1\u670d\u52a1\u5668\nmkdocs serve\n</code></pre>"},{"location":"blog/posts/getting-started-with-mkdocs-material/#_3","title":"\u540e\u7eed\u8ba1\u5212","text":"<p>\u6211\u6253\u7b97\u5199\u4ee5\u4e0b\u4e3b\u9898\uff1a</p> <ul> <li>Python \u6280\u5de7\u4e0e\u7a8d\u95e8</li> <li>\u8f6f\u4ef6\u67b6\u6784\u6a21\u5f0f</li> <li>DevOps \u5de5\u4f5c\u6d41</li> <li>\u5f00\u6e90\u8d21\u732e</li> </ul> <p>\u656c\u8bf7\u671f\u5f85\u66f4\u591a\u6587\u7ae0\uff01</p> <p>Happy coding!</p>"},{"location":"blog/posts/python-decorators-explained/","title":"\u6df1\u5165\u6d45\u51fa Python \u88c5\u9970\u5668","text":"<p>\u88c5\u9970\u5668\u662f Python \u6700\u4f18\u96c5\u7684\u7279\u6027\u4e4b\u4e00\uff0c\u4f46\u521d\u5b66\u8005\u5f80\u5f80\u89c9\u5f97\u96be\u4ee5\u7406\u89e3\u3002\u8ba9\u6211\u4eec\u628a\u5b83\u62c6\u5f00\u6765\u770b\u3002</p>"},{"location":"blog/posts/python-decorators-explained/#_1","title":"\u4ec0\u4e48\u662f\u88c5\u9970\u5668\uff1f","text":"<p>\u88c5\u9970\u5668\u672c\u8d28\u4e0a\u662f\u4e00\u4e2a\u51fd\u6570\uff0c\u5b83\u63a5\u6536\u53e6\u4e00\u4e2a\u51fd\u6570\u4f5c\u4e3a\u53c2\u6570\uff0c\u5728\u4e0d\u4fee\u6539\u539f\u51fd\u6570\u7684\u60c5\u51b5\u4e0b\u6269\u5c55\u5176\u529f\u80fd\u3002</p> <pre><code>def my_decorator(func):\n    def wrapper():\n        print(\"\u51fd\u6570\u6267\u884c\u524d\")\n        func()\n        print(\"\u51fd\u6570\u6267\u884c\u540e\")\n    return wrapper\n\n@my_decorator\ndef say_hello():\n    print(\"Hello!\")\n\nsay_hello()\n</code></pre> <p>\u8f93\u51fa\uff1a</p> <pre><code>\u51fd\u6570\u6267\u884c\u524d\nHello!\n\u51fd\u6570\u6267\u884c\u540e\n</code></pre>"},{"location":"blog/posts/python-decorators-explained/#_2","title":"\u539f\u7406\u63ed\u79d8","text":"<p><code>@my_decorator</code> \u8bed\u6cd5\u53ea\u662f\u4ee5\u4e0b\u4ee3\u7801\u7684\u8bed\u6cd5\u7cd6\uff1a</p> <pre><code>say_hello = my_decorator(say_hello)\n</code></pre>"},{"location":"blog/posts/python-decorators-explained/#_3","title":"\u5b9e\u6218\u793a\u4f8b\uff1a\u8ba1\u65f6\u88c5\u9970\u5668","text":"<pre><code>import time\nfrom functools import wraps\n\ndef timer(func):\n    @wraps(func)\n    def wrapper(*args, **kwargs):\n        start = time.perf_counter()\n        result = func(*args, **kwargs)\n        end = time.perf_counter()\n        print(f\"{func.__name__} \u8017\u65f6 {end - start:.4f} \u79d2\")\n        return result\n    return wrapper\n\n@timer\ndef compute_heavy():\n    total = sum(i * i for i in range(10_000_000))\n    return total\n\ncompute_heavy()\n</code></pre>"},{"location":"blog/posts/python-decorators-explained/#wraps","title":"\u4e3a\u4ec0\u4e48\u7528 <code>@wraps</code>\uff1f","text":"<p>\u4e0d\u4f7f\u7528 <code>functools.wraps</code> \u7684\u8bdd\uff0c\u88ab\u88c5\u9970\u7684\u51fd\u6570\u4f1a\u4e22\u5931\u5143\u6570\u636e \u2014\u2014 <code>__name__</code>\u3001<code>__doc__</code> \u7b49\u3002\u6240\u4ee5\u52a1\u5fc5\u52a0\u4e0a\u5b83\u3002</p>"},{"location":"blog/posts/python-decorators-explained/#_4","title":"\u88c5\u9970\u5668\u7684\u5e94\u7528\u573a\u666f","text":"<ul> <li>\u65e5\u5fd7\u8bb0\u5f55 \u2014 \u81ea\u52a8\u8bb0\u5f55\u51fd\u6570\u8c03\u7528</li> <li>\u7f13\u5b58 \u2014 \u4f7f\u7528 <code>@lru_cache</code> \u5b9e\u73b0\u8bb0\u5fc6\u5316</li> <li>\u6743\u9650\u6821\u9a8c \u2014 \u5728\u6267\u884c\u524d\u68c0\u67e5\u6743\u9650</li> <li>\u53c2\u6570\u9a8c\u8bc1 \u2014 \u5904\u7406\u524d\u6821\u9a8c\u53c2\u6570</li> <li>\u91cd\u8bd5\u673a\u5236 \u2014 \u5931\u8d25\u65f6\u6309\u9000\u907f\u7b56\u7565\u91cd\u8bd5</li> </ul> <p>\u88c5\u9970\u5668\u8ba9\u4f60\u80fd\u5e72\u51c0\u5730\u5206\u79bb\u6a2a\u5207\u5173\u6ce8\u70b9\u3002\u4e00\u65e6\u638c\u63e1\u4e86\u5b83\uff0c\u4f60\u4f1a\u53d1\u73b0\u5230\u5904\u90fd\u80fd\u7528\u4e0a\u3002</p> <p>\u5bf9\u88c5\u9970\u5668\u6709\u7591\u95ee\uff1f\u6b22\u8fce\u5728\u8bc4\u8bba\u533a\u4ea4\u6d41\uff01</p>"}]}